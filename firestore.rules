rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Narrowly scoped connection test collection for Stage 5 verification
    match /connection_tests/{userId} {
      allow create, read, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Real Civic Issues collection rules for Stage 8
    // Trusted issue creation occurs via FastAPI Admin SDK.
    // Clients can read issues, but cannot directly create or mutate trusted server fields.
    match /issues/{issueId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false; // Only FastAPI Admin SDK can create/mutate
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
